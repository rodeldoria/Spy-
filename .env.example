# Settings consumed by the Monte engine and the Spy- Streamlit UI.

# Optional — only needed if you want AI sentiment to participate in triangulation.
ANTHROPIC_API_KEY=
# Optional — when set, the watchlist will fetch a 48h news brief per symbol
# from Perplexity (`sonar` model) to confirm/conflict the technical signal.
PERPLEXITY_API_KEY=

# Optional — Alpaca paper trading for SPY (crypto uses the local sim paper book).
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
MONTE_ALLOW_LIVE=0

# Watchlists. JSON-encoded lists.
MONTE_CRYPTO_WATCHLIST=["BTC-USD","ETH-USD","SOL-USD"]
MONTE_STOCK_WATCHLIST=["SPY"]

# Paper-book starting budget. Defaults to a $500 real-world ramp.
MONTE_BUDGET_USD=500
# Monthly profit target shown on the dashboard. Informational only — no
# automated execution, just a progress pill so you can see how the book
# is tracking against the goal.
MONTE_MONTHLY_TARGET_USD=4000

# Goal plan (Monte Edge). Start / target / deadline for the goal-tracker page
# and the suggested-risk-per-trade calc on the budget page.
MONTE_GOAL_START_USD=10000
MONTE_GOAL_TARGET_USD=15000
MONTE_GOAL_DEADLINE=2026-11-13

# Push notifications (ntfy.sh). Install the ntfy app on your phone, subscribe
# to the same topic, and ACT_NOW / WATCH alerts land as native pushes.
# Pick something unguessable — anyone with the topic name can read it.
MONTE_NTFY_TOPIC=
MONTE_NTFY_SERVER=https://ntfy.sh

# Monte Edge gating. Confluence is how many of the 5 contributors must agree
# with the signal direction. Higher = fewer signals, higher hit-rate.
MONTE_CONFLUENCE_MIN=3
MONTE_RISK_MAX_PCT=1.5

# Where Claude's playbook (signal log) is stored.
MONTE_PLAYBOOK_PATH=~/.monte/playbook.jsonl

# Local paths.
MONTE_VECTOR_DB_PATH=~/.monte/chroma
MONTE_PAPER_STATE_PATH=~/.monte/paper
MONTE_ALERTS_LOG_PATH=~/.monte/alerts.jsonl
# Pattern journal (records entries/exits so the watchlist can show "you've
# traded this setup N times, win-rate X%").
MONTE_JOURNAL_PATH=~/.monte/journal.jsonl

# Alert threshold (0–100).
MONTE_MIN_CONFIDENCE=65

# Slippage applied to paper fills, in basis points.
MONTE_SLIPPAGE_BPS=5

# Pattern-encoder window length (bars).
MONTE_PATTERN_WINDOW=60
