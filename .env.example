# Settings consumed by the Monte engine and the Spy- Streamlit UI.

# Optional — only needed if you want AI sentiment to participate in triangulation.
ANTHROPIC_API_KEY=
# Optional — when set, the watchlist will fetch a 48h news brief per symbol
# from Perplexity (`sonar` model) to confirm/conflict the technical signal.
PERPLEXITY_API_KEY=

# Optional — Alpaca paper trading for SPY (crypto uses the local sim paper book).
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
MONTE_ALLOW_LIVE=0

# Watchlists. JSON-encoded lists.
MONTE_CRYPTO_WATCHLIST=["BTC-USD","ETH-USD","SOL-USD"]
MONTE_STOCK_WATCHLIST=["SPY"]

# Paper-book starting budget.
MONTE_BUDGET_USD=10000

# Local paths.
MONTE_VECTOR_DB_PATH=~/.monte/chroma
MONTE_PAPER_STATE_PATH=~/.monte/paper
MONTE_ALERTS_LOG_PATH=~/.monte/alerts.jsonl
# Pattern journal (records entries/exits so the watchlist can show "you've
# traded this setup N times, win-rate X%").
MONTE_JOURNAL_PATH=~/.monte/journal.jsonl

# Alert threshold (0–100).
MONTE_MIN_CONFIDENCE=65

# Slippage applied to paper fills, in basis points.
MONTE_SLIPPAGE_BPS=5

# Pattern-encoder window length (bars).
MONTE_PATTERN_WINDOW=60
